# Copie este arquivo para .env e preencha os valores reais
# Execute: cp .env.example .env

# Versão exibida pelo endpoint /health
APP_VERSION=4.0.0-rc.1

# OBRIGATÓRIO: Chave secreta para sessões Flask
# Gere uma nova com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui

# OBRIGATÓRIO: URL de conexão com o PostgreSQL (dentro da rede Docker)
DATABASE_URL=postgresql://clinica_user:senha_segura_aqui@postgres:5432/clinica

# OBRIGATÓRIO: Senha do PostgreSQL (usada pelo serviço postgres no Docker Compose)
POSTGRES_PASSWORD=senha_segura_aqui

# OBRIGATÓRIO: URL do Redis (broker Celery + rate limiting + cache)
REDIS_URL=redis://redis:6379/0

# OBRIGATÓRIO para criar o admin inicial via create_admin.py
# Uso: docker compose run --rm gestaoclinica python create_admin.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque_para_senha_forte

# Backup operacional
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_HOUR=2
BACKUP_SCHEDULE_MINUTE=30
BACKUP_RUN_ON_START=true
BACKUP_OFFSITE_ENABLED=true
BACKUP_OFFSITE_RETENTION_DAYS=90
BACKUP_RCLONE_REMOTE=sorriso.drive:backup_vps_snapshots/GestaoSaudeOral/database

# Google Drive / armazenamento externo
# Use Service Account. Nunca use senha de conta Google no sistema.
GDRIVE_KEY_PATH=/run/secrets/sorriso/sorriso-google-drive-service-account.json
# Uploads em "Meu Drive" devem usar OAuth de usuário via rclone. A Service
# Account continua limitada a metadados/pastas e não possui cota de armazenamento.
GDRIVE_UPLOAD_MODE=rclone
GDRIVE_RCLONE_CONFIG=/run/secrets/rclone/rclone.conf
GDRIVE_RCLONE_REMOTE=sorriso.drive
GDRIVE_OAUTH_EMAIL=sorrisodagentealagoas@gmail.com
# Monte o diretório, não o arquivo individual. O rclone renova o token por
# substituição atômica de rclone.conf e precisa criar/renomear arquivos ao lado.
RCLONE_CONFIG_HOST_DIR=./secrets/rclone
# Opcional, recomendado: ID da pasta "Prontuários" compartilhada com a Service Account.
GDRIVE_ROOT_FOLDER_ID=
GDRIVE_PATIENTS_FOLDER_NAME=Prontuários
# Staging persistente: o request salva localmente e o Celery sincroniza com o Drive.
EXAM_FILE_STAGING_DIR=uploads/staging/exams
EXAM_FILE_SYNC_MAX_ATTEMPTS=100
# Entrega rápida e protegida via Nginx.
UPLOADS_HOST_PATH=/srv/gestaosaudeoral/uploads
UPLOADS_ROOT=uploads
USE_X_ACCEL_REDIRECT=true
X_ACCEL_INTERNAL_PREFIX=/_protected_exam_files/
X_ACCEL_FILE_GID=33
GDRIVE_LOCAL_CACHE_DIR=uploads/cache/gdrive
GDRIVE_CACHE_TTL_SECONDS=172800
GDRIVE_CACHE_LIMIT_GB=15
GDRIVE_CACHE_HIGH_WATERMARK=0.80
GDRIVE_CACHE_TARGET_WATERMARK=0.70
EXAM_DERIVATIVE_DIR=uploads/derived/exam-files
# Upload clínico: limites de contenção amplos e ajustáveis. O original nunca é
# reduzido; apenas miniaturas/prévias usam compactação WebP sem perda.
CLINICAL_UPLOAD_MAX_FILE_MB=300
CLINICAL_UPLOAD_MAX_REQUEST_MB=320
CLINICAL_IMAGE_MAX_WIDTH=50000
CLINICAL_IMAGE_MAX_HEIGHT=50000
CLINICAL_IMAGE_MAX_PIXELS=150000000
CLINICAL_IMAGE_MAX_TOTAL_PIXELS=300000000
CLINICAL_IMAGE_MAX_FRAMES=512
CLINICAL_PDF_MAX_PAGES=10000
CLINICAL_IMAGE_DERIVATIVE_LOSSLESS=true

# Relatórios governamentais automáticos
REPORTS_OUTPUT_DIR=pdf_temp
REPORTS_SCHEDULER_ENABLED=true
REPORTS_SCHEDULE_DAY=1
REPORTS_SCHEDULE_HOUR=2
REPORTS_SCHEDULE_MINUTE=20
REPORTS_SCHEDULE_TYPES=all
TZ=America/Maceio

# E-mail transacional / recuperacao de senha
APP_BASE_URL=https://sorrisodagentealagoas.com
SMTP_HOST=mail
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=nao-responda@sorrisodagentealagoas.com

# SIGTAP — Catálogo de Procedimentos DataSUS
# Substituir pela competência do mês vigente quando importar o SIGTAP oficial.
SIGTAP_DEFAULT_COMPETENCE=202603

# ─── e-SUS APS — Integração por Arquivo XML Quinzenal ────────────────────────
# ⚠️  ATENÇÃO: Preencher com os dados fornecidos pelo TI da Secretaria de Saúde
#              (Rômulo / Ronaldo). Sem esses valores, a remessa fica bloqueada.
#
# CNES: Código Nacional de Estabelecimentos de Saúde (7 dígitos)
ESUS_CNES=
# INE: Identificador Nacional de Equipes (10 dígitos)
ESUS_INE=
# Município da instalação (código IBGE com 7 dígitos)
ESUS_COD_IBGE=
# Identificação LEDI fornecida/configurada no PEC municipal
ESUS_CONTRA_CHAVE=
ESUS_UUID_INSTALACAO=
# Responsável pela instalação originadora
ESUS_CPF_CNPJ=
ESUS_NOME_RAZAO_SOCIAL=
ESUS_FONE=
ESUS_EMAIL_INSTITUCIONAL=
# Metadados do software e versão do transporte LEDI homologada pelo município
ESUS_VERSAO_SISTEMA=GestaoSaudeOral 2.8
ESUS_NOME_BANCO_DADOS=PostgreSQL
ESUS_VERSAO_MAJOR=7
ESUS_VERSAO_MINOR=2
ESUS_VERSAO_REVISION=1
# E-mail de destino (TI da Secretaria de Saúde):
ESUS_EMAIL_DESTINO=
# Ativar envio automático (true/false):
ESUS_REMESSA_ATIVA=false
# Dias de envio das remessas quinzenais (padrão: dia 15 e dia 5):
ESUS_REMESSA_DIA_P1=15
ESUS_REMESSA_DIA_P2=5
# Horário do Celery Beat para verificação (padrão: 06:00):
ESUS_REMESSA_HORA=6
ESUS_REMESSA_MINUTO=0
