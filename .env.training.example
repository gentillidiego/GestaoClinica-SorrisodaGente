# Copie para .env.training antes de subir o ambiente.
APP_VERSION=4.0.0-rc.1-training
SECRET_KEY=troque-esta-chave-exclusiva-do-ambiente-de-treinamento

TRAINING_HOST_PORT=5103
TRAINING_MAIL_PORT=5125
TRAINING_POSTGRES_PASSWORD=troque-esta-senha-local
TRAINING_DEFAULT_PASSWORD=Treino@2026!
TRAINING_ENVIRONMENT=true

SESSION_COOKIE_SECURE=false
APP_BASE_URL=http://127.0.0.1:5103
FLASK_DEBUG=false
TZ=America/Maceio

REPORTS_SCHEDULER_ENABLED=false
ESUS_REMESSA_ATIVA=false
BACKUP_OFFSITE_ENABLED=false
BACKUP_RUN_ON_START=false

# Não há worker Celery no ambiente de treinamento. Uploads permanecem locais.
GDRIVE_UPLOAD_MODE=disabled
UPLOADS_ROOT=uploads
EXAM_FILE_STAGING_DIR=uploads/staging/exams
USE_X_ACCEL_REDIRECT=false

SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=treinamento@sorrisodagente.local

SIGTAP_DEFAULT_COMPETENCE=202603
